{
  "name": "email-server",
  "version": "0.2.0",
  "description": "Easily run your own mail server - complete email infrastructure with full control, in a single Node.js.",
  "main": "index.js",
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs",
      "default": "./index.js"
    },
    "./wire":     "./src/smtp_wire.js",
    "./smtp":     "./src/smtp_session.js",
    "./imap":     "./src/imap_session.js",
    "./pop3":     "./src/pop3_session.js",
    "./session":  "./src/smtp_session.js",
    "./message":  "./src/message.js",
    "./dkim":     "./src/dkim.js",
    "./spf":      "./src/spf.js",
    "./dmarc":    "./src/dmarc.js",
    "./dsn":      "./src/dsn.js",
    "./domain":   "./src/domain.js"
  },
  "files": [
    "index.js",
    "index.cjs",
    "index.d.ts",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "smtp",
    "imap",
    "pop3",
    "email",
    "mail",
    "smtp-server",
    "smtp-client",
